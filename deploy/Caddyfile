# Real domains via LANDING_DOMAIN / DASH_DOMAIN / APP_DOMAIN get automatic
# Let's Encrypt TLS; dash/app default to self-signed HTTPS (PWA/camera need a
# secure context) while the landing page defaults to plain HTTP locally so
# typing localhost:8085 just works — set LANDING_DOMAIN for real TLS.
{$LANDING_DOMAIN:http://localhost:8085} {
	encode gzip
	root * /srv/site
	file_server
}

{$DASH_DOMAIN:localhost:8443} {
	encode gzip
	handle /api/* {
		reverse_proxy api:8000
	}
	handle {
		root * /srv/dash
		try_files {path} /index.html
		file_server
	}
}

{$APP_DOMAIN:localhost:8444} {
	encode gzip
	handle /api/* {
		reverse_proxy api:8000
	}
	handle {
		root * /srv/app
		try_files {path} /index.html
		file_server
	}
}
