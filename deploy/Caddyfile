# Real domains via LANDING_DOMAIN / DASH_DOMAIN / APP_DOMAIN get automatic
# Let's Encrypt TLS; the defaults serve self-signed HTTPS on local ports.
{$LANDING_DOMAIN:localhost:8085} {
	encode gzip
	root * /srv/site
	file_server
}

{$DASH_DOMAIN:localhost:8443} {
	encode gzip
	handle /api/* {
		reverse_proxy api:8000
	}
	handle {
		root * /srv/dash
		try_files {path} /index.html
		file_server
	}
}

{$APP_DOMAIN:localhost:8444} {
	encode gzip
	handle /api/* {
		reverse_proxy api:8000
	}
	handle {
		root * /srv/app
		try_files {path} /index.html
		file_server
	}
}
